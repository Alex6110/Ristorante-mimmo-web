---
import '../styles/global.css';
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ristorante Mimmo | Scegli la tua destinazione</title>
    <meta name="robots" content="noindex" /> 
    <link rel="icon" type="image/svg+xml" href="/logo-mimmo.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style is:global>
      :root {
        --c-accento: #fdf6e9; 
        --c-scuro: #b44310; 
        --c-sfondo: #fdf6e9; 
        --c-carta: #fcf5e5;
        --c-testo: #043585;
        --c-testo-rgb: 4, 53, 133;
      }

      body {
        background-color: var(--c-sfondo);
        margin: 0;
        padding: 0;
      }

      #pattern-overlay {
        position: fixed; 
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        background-image: url("/pattern-geometrico.PNG");
        background-repeat: repeat;
        background-size: 120px;
        opacity: 0.3;
      }

      .container-mimmo {
        background-color: var(--c-carta); /* Resta il colore del sito */
        border: 2px solid var(--c-testo);
        border-radius: 60px 60px 30px 30px; 
        position: relative;
        box-shadow: 0 25px 50px rgba(0,0,0,0.15);
        z-index: 1;
        /* HO RIMOSSO IL ::BEFORE CHE CARICAVA LA TEXTURE */
      }
    </style>
  </head>
  
  <body class="text-[var(--c-testo)] font-['Poppins'] min-h-screen">
    
    <div id="pattern-overlay"></div>

    <div class="w-full px-4 py-12 mx-auto flex justify-center">
        
      <div class="container-mimmo w-full max-w-md px-6 py-10 text-center">
        
        <div class="mb-8 text-[var(--c-scuro)]">
          <h1 class="font-['Playfair_Display'] text-3xl font-bold mb-2">Ristorante Mimmo</h1>
          <p class="text-sm opacity-80 uppercase tracking-widest">Scegli come proseguire</p>
        </div>

        <div class="space-y-10 relative z-10">
          
          <a href="https://www.ristorantebarmimmo.com" class="block group no-underline">
            <div class="relative overflow-hidden rounded-2xl border border-[var(--c-testo)]/30 shadow-lg aspect-video">
                <img 
                src="/cover-sito.webp" 
                alt="Sito Web" 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                onerror="this.style.display='none'; this.parentElement.style.backgroundColor='rgba(var(--c-testo-rgb), 0.1)';"
                />
            </div>
            <p class="mt-4 font-semibold text-lg uppercase tracking-widest group-hover:text-[var(--c-scuro)] transition-colors">
                Vai al sito web
            </p>
          </a>

          <a href="https://www.google.com/maps/place/Mimmo+Bar/@44.301698,8.4732726,3169m/data=!3m1!1e3!4m10!1m2!2m1!1sristorante+bar+mimmo+!3m6!1s0x12d2e203f19c5961:0xed25a81855c05396!8m2!3d44.3064984!4d8.4777998!15sChRyaXN0b3JhbnRlIGJhciBtaW1tb1oWIhRyaXN0b3JhbnRlIGJhciBtaW1tb5IBCnJlc3RhdXJhbnSaAURDaTlEUVVsUlFVTnZaRU5vZEhsalJqbHZUMnhLTlZKcmNIaGtNamxUVmpOQ1dGUklXbHBWTTJoelZGWndRbGt5WXhBQuABAPoBBQipARBI!16s%2Fg%2F11wxb0fhr6?authuser=0&entry=ttu&g_ep=EgoyMDI2MDQyMi4wIKXMDSoASAFQAw%3D%3D" target="_blank" rel="noopener noreferrer" class="block group no-underline">
            <div class="relative overflow-hidden rounded-2xl border border-[var(--c-testo)]/30 shadow-lg aspect-video">
                <img 
                src="/cover-mappa.webp" 
                alt="Mappa" 
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                onerror="this.style.display='none'; this.parentElement.style.backgroundColor='rgba(var(--c-testo-rgb), 0.1)';"
                />
            </div>
            <p class="mt-4 font-semibold text-lg uppercase tracking-widest group-hover:text-[var(--c-scuro)] transition-colors">
                Come raggiungerci
            </p>
          </a>

        </div>
      </div>
      
    </div>

  </body>
</html>