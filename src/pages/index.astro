      <section id="locale" class="container-mimmo px-4 py-8 md:p-12 scroll-mt-36 md:scroll-mt-40 text-center">
        <div class="section-ornate-title mb-4 md:mb-8">
          <h2 class="font-['Playfair_Display'] text-2xl md:text-4xl font-bold">Il Locale</h2>
