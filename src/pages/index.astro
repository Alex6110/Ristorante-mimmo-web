    </footer>

    <script>
		// 1. Forza manual restoration IMMEDIATAMENTE
		if ('scrollRestoration' in history) {
			history.scrollRestoration = 'manual';
		}

		// 2. Forza il top all'istante
		window.scrollTo(0, 0);

		const mainLinks = document.querySelectorAll('.main-link');
		const subLinks = document.querySelectorAll('.sub-link');
		const mainSections = document.querySelectorAll('section#locale, main#menu, footer#contatti');
		const subSections = document.querySelectorAll('.menu-category-section');
		const subNav = document.getElementById('sub-nav');

		// Funzione per inizializzare gli Observer (chiamata solo dopo lo sblocco)
		const initObservers = () => {
			// Observer Principale
			const mainObserver = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
				mainLinks.forEach(link => {
					if (link.getAttribute('href') === '#' + entry.target.id) {
						// Applichiamo la classe solo se non c'è già (evita ricalcoli inutili)
						if (!link.classList.contains('nav-link-active')) {
							link.classList.add('nav-link-active');
							
							// Scroll fluido del menù orizzontale senza bloccare la pagina
							const parent = link.parentElement;
							const offset = link.offsetLeft - (parent.offsetWidth / 2) + (link.offsetWidth / 2);
							parent.scrollTo({ left: offset, behavior: 'smooth' });
						}
					} else {
						link.classList.remove('nav-link-active');
					}
				});
				// Gestione sottomenu
				if (entry.target.id === 'menu') {
					subNav.classList.add('is-open');
				} else {
					subNav.classList.remove('is-open');
				}
				}
			});
			}, { rootMargin: '-20% 0px -70% 0px' });

			mainSections.forEach(section => mainObserver.observe(section));

			// Observer Sottomenu
			const subObserver = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
				// Dentro subObserver -> entries.forEach -> if (entry.isIntersecting)
			subLinks.forEach(link => {
				if (link.getAttribute('href') === '#' + entry.target.id) {
					if (!link.classList.contains('nav-link-active')) {
						link.classList.add('nav-link-active', 'text-[var(--c-accento)]');
						
						// Scroll fluido del sottomenù
						const parent = link.parentElement;
						const offset = link.offsetLeft - (parent.offsetWidth / 2) + (link.offsetWidth / 2);
						parent.scrollTo({ left: offset, behavior: 'smooth' });
					}
				} else {
					link.classList.remove('nav-link-active', 'text-[var(--c-accento)]');
				}
			});
				}
			});
			}, { rootMargin: '-30% 0px -60% 0px' });

			subSections.forEach(section => subObserver.observe(section));
		};

		// 3. SBLOCCO PAGINA
		window.addEventListener('load', () => {
			// Piccolo delay per dare tempo a Safari di finire i calcoli di layout
			setTimeout(() => {
			window.scrollTo(0, 0);
			document.documentElement.classList.remove('is-loading');
			
			// Ora che la pagina è ferma in cima, attiviamo lo scroll smooth e gli observer
			document.documentElement.style.scrollBehavior = 'smooth';
			initObservers();
			}, 100);
		});
		// Gestione Tooltip Universale (Allergeni)
      document.addEventListener('click', (e) => {
        const badge = e.target.closest('.allergen-badge');
        const allBadges = document.querySelectorAll('.allergen-badge');

        if (badge) {
          e.stopPropagation();
          const isActive = badge.classList.contains('is-active');
          allBadges.forEach(b => b.classList.remove('is-active'));
          if (!isActive) {
            badge.classList.add('is-active');
          }
        } else {
          allBadges.forEach(b => b.classList.remove('is-active'));
        }
      });
    
      // ==========================================
      // LOGICA GALLERIA LIGHTBOX A SCORRIMENTO (CON DOTS E CORNICE DINAMICA)
      // ==========================================
      document.addEventListener('DOMContentLoaded', () => {
        const triggers = document.querySelectorAll('.gallery-trigger');
        const images = [];
        let currentIndex = 0;

        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        const btnClose = document.getElementById('lightbox-close');
        const dotsContainer = document.getElementById('lightbox-dots'); // Nuovo contenitore dots
        const btnNext = document.getElementById('lightbox-next');
        const btnPrev = document.getElementById('lightbox-prev');

        if (triggers.length > 0 && lightbox) {
          
          if (btnNext) btnNext.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });
          if (btnPrev) btnPrev.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
          // 1. Raccoglie tutte le immagini
          triggers.forEach((trigger, index) => {
            const imgEl = trigger.querySelector('img');
            if (imgEl) {
              images.push(imgEl.src);
              trigger.onclick = (e) => {
                e.preventDefault();
                openLightbox(index);
              };
            }
          });

          // 2. Genera i pallini (Dots) in base al numero di immagini
          function generateDots() {
            dotsContainer.innerHTML = ''; // Pulisce eventuali pallini vecchi
            images.forEach((_, index) => {
              const dot = document.createElement('div');
              dot.classList.add('lightbox-dot');
              if (index === currentIndex) dot.classList.add('active');
              
              // Rende i pallini cliccabili
              dot.onclick = (e) => {
                e.stopPropagation(); // Evita di chiudere la lightbox
                if (currentIndex !== index) {
                  currentIndex = index;
                  updateLightboxImage();
                }
              };
              dotsContainer.appendChild(dot);
            });
          }

          // 3. Aggiorna quale pallino è attivo
          function updateDots() {
            const dots = document.querySelectorAll('.lightbox-dot');
            dots.forEach((dot, index) => {
              if (index === currentIndex) {
                dot.classList.add('active');
              } else {
                dot.classList.remove('active');
              }
            });
          }

          // 4. Funzioni di apertura/chiusura
          function openLightbox(index) {
            currentIndex = index;
            generateDots(); // Genera i pallini quando apri
            updateLightboxImage();
            lightbox.style.display = 'flex';
            setTimeout(() => lightbox.classList.add('is-visible'), 10);
            document.body.style.overflow = 'hidden';
          }

          function closeLightbox() {
            lightbox.classList.remove('is-visible');
            setTimeout(() => {
              lightbox.style.display = 'none';
              document.body.style.overflow = ''; 
            }, 300);
          }

          // 5. Aggiornamento immagine con dissolvenza
          function updateLightboxImage() {
            lightboxImg.style.opacity = '0';
            lightboxImg.style.transform = 'scale(0.98)';

            setTimeout(() => {
              const newImg = new Image();
              newImg.src = images[currentIndex];

              newImg.onload = () => {
                lightboxImg.src = newImg.src;
                updateDots(); // Aggiorna i pallini invece del testo
                
                setTimeout(() => {
                  lightboxImg.style.opacity = '1';
                  lightboxImg.style.transform = 'scale(1)';
                }, 50); 
              };
            }, 200);
          }

          function nextImage() {
            currentIndex = (currentIndex + 1) % images.length;
            updateLightboxImage();
          }

          function prevImage() {
            currentIndex = (currentIndex - 1 + images.length) % images.length;
            updateLightboxImage();
          }

          // 6. Gestione click intelligente (Navigazione laterale su tutta l'area)
          lightbox.addEventListener('click', (e) => {
            // Se clicchi sul tasto chiudi
            if (e.target === btnClose || e.target.closest('#lightbox-close')) {
              closeLightbox();
              return;
            }

            // Se clicchi sull'immagine o nell'area laterale navighi
            // Misuriamo dove l'utente ha cliccato rispetto allo schermo
            const clickX = e.clientX;
            const screenWidth = window.innerWidth;

            if (clickX > screenWidth / 2) {
              nextImage();
            } else {
              prevImage();
            }
          });

          // 7. Controlli Tastiera
          document.addEventListener('keydown', (e) => {
            if (!lightbox.classList.contains('is-visible')) return;
            if (e.key === 'Escape') closeLightbox();
            if (e.key === 'ArrowRight') nextImage();
            if (e.key === 'ArrowLeft') prevImage();
          });
        }
      });
      // ==========================================
      // LOGICA PULSANTE "TORNA SU"
      // ==========================================
      document.addEventListener('DOMContentLoaded', () => {
        const backToTopBtn = document.getElementById('backToTop');

        if (backToTopBtn) {
          // Controlla lo scroll per mostrare/nascondere il pulsante
          window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
              backToTopBtn.classList.add('is-visible');
            } else {
              backToTopBtn.classList.remove('is-visible');
            }
          });

          // Cliccando, torna all'inizio in modo fluido
          backToTopBtn.addEventListener('click', () => {
            window.scrollTo({
              top: 0,
              behavior: 'smooth'
            });
          });
        }
      });
	  </script>
    <button id="backToTop" class="back-to-top" aria-label="Torna all'inizio">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>
  </body>
